    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Full Example",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/resident",
            "program": "simulation.py",
            "console": "integratedTerminal",
            "args": [
                "-c", "configs", // check the settings.yaml file for run settings!
                // "-d", "model_data/metro/data_full",
                // "-o", "outputs/20_pct_new_trn_spec_no_pnr",
                "-d", "C:/projects/odot_joint_estimation/pnr/tasks/run_dir_new_zones/input",
                "-o", "C:/projects/odot_joint_estimation/pnr/tasks/run_dir_new_zones/output",
            ]
        },
        {
            "name": "Run Cropped Example",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/resident",
            "program": "simulation.py",
            "console": "integratedTerminal",
            "args": [
                "-c", "configs", // check the settings.yaml file for run settings!
                "-d", "model_data/metro/data_cropped",
                "-o", "outputs/test",
            ]
        },
        {
            "name": "Run Preprocessor",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/resident",
            "program": "preprocessor.py",
            "console": "integratedTerminal",
            "args": "preprocessor_settings.yaml"
        }
    ]
}